# Default public test server (no authentication required)
# Options: hapi | firely | spark | wildfhir
# See docs/public-test-servers.md for details
FHIR_DEFAULT_SERVER_KEY=hapi

# Optional URL overrides (uncomment to use a custom server)
# FHIR_METADATA_URL=https://hapi.fhir.org/baseR4/metadata
# FHIR_SERVER_BASE=https://hapi.fhir.org/baseR4

# Authentication — false for all built-in public test servers
FHIR_USE_AUTH=false
# TOKEN_URL=
# CLIENT_ID=
# CLIENT_SECRET=