# Default public test server (no authentication required)
# Options: hapi | firely | spark | wildfhir
# See docs/public-test-servers.md for details
FHIR_DEFAULT_SERVER_KEY=hapi

# Optional URL overrides (uncomment to use a custom server)
# FHIR_METADATA_URL=https://hapi.fhir.org/baseR4/metadata
# FHIR_SERVER_BASE=https://hapi.fhir.org/baseR4

# Authentication — false for all built-in public test servers
FHIR_USE_AUTH=false
# TOKEN_URL=
# CLIENT_ID=
# CLIENT_SECRET=

# CapabilityStatement cache (in-memory, per process)
FHIR_CAPABILITY_CACHE_ENABLED=true
FHIR_CAPABILITY_CACHE_TTL_SECONDS=86400

# Maximum CapabilityStatement / OAuth token response size (bytes, default 10MB)
# FHIR_MAX_METADATA_RESPONSE_BYTES=10485760

# Outbound HTTP rate limit per metadata/OAuth host (default 30 requests / 60 seconds)
# FHIR_OUTBOUND_RATE_LIMIT_PER_HOST=30
# FHIR_OUTBOUND_RATE_LIMIT_WINDOW_SECONDS=60